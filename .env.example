APP_NAME=meeting-pipeline
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

DATA_ROOT=data
RAW_DATA_DIR=data/raw
INTERIM_DATA_DIR=data/interim
PROCESSED_DATA_DIR=data/processed
EVAL_DATA_DIR=data/eval

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meeting_rag
POSTGRES_USER=meeting_user
POSTGRES_PASSWORD=change-me
PGVECTOR_COLLECTION=meeting_chunks

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=nomic-embed-text-v2-moe
OLLAMA_CHAT_MODEL=qwen3:4b

DEFAULT_FACTOID_TOP_K=5
SPEAKER_SPECIFIC_TOP_K=4
ACTION_ITEMS_OR_DECISIONS_TOP_K=8
BROAD_SUMMARY_TOP_K=14
META_OR_CONFIDENCE_TOP_K=6
BROAD_SUMMARY_MAX_CANDIDATES=28
RETRIEVAL_CHUNK_WINDOW_SECONDS=45
RETRIEVAL_CHUNK_OVERLAP_SECONDS=15
ENABLE_RAG_CACHING=true
QUERY_REWRITE_CACHE_SIZE=256
QUERY_EMBEDDING_CACHE_SIZE=512
RETRIEVAL_BUNDLE_CACHE_SIZE=256
ANSWER_CACHE_SIZE=256
ANSWER_MAX_EVIDENCE_CHUNKS=12
ANSWER_MAX_EVIDENCE_CHARS=12000
ANSWER_MAX_CHUNK_CHARS=600
ENABLE_FAST_MODE=false
FAST_MODE_SKIP_QUERY_REWRITE=true
FAST_MODE_POLICY_TOP_K_CAP=6
FAST_MODE_ANSWER_MAX_EVIDENCE_CHUNKS=8
FAST_MODE_ANSWER_MAX_EVIDENCE_CHARS=7500
FAST_MODE_ANSWER_MAX_CHUNK_CHARS=420

WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=8

PYANNOTE_AUTH_TOKEN=
HUGGINGFACE_TOKEN=

STREAMLIT_SERVER_PORT=8501
